geom_bar(stat = "identity") +
theme_classic() +
xlab("Area") +
ylab("Mean Value") +
scale_fill_manual(values = c(
"red", "magenta", "red", "magenta",
"red", "magenta", "red", "magenta"
))
dat <- read.csv("firstlength.csv")
# Convert Area from µm to mm
dat$Area_mm <- dat$Area / 1000
# Round
dat$Area_mm <- round(dat$Area_mm, 6)
# Convert to factor for  x-axis
dat$Area_mm <- factor(dat$Area_mm)
ggplot(dat, aes(x = Area_mm, y = Mean, fill = Area_mm)) +
geom_bar(stat = "identity") +
theme_classic() +
xlab("Area") +
ylab("Mean Value") +
scale_fill_manual(values = c(
"red", "magenta", "red", "magenta",
"red", "magenta", "red", "magenta"
))
