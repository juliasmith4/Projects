library(dplyr)
dat_1951 <- dat %>%
filter(year >= 1951)
head(dat_1951)
x <- (dat_1951$year)
y <- (dat_1951$annual_temp_c)
summary(x)
summary(y)
model_1951 <- lm(y ~ x)
model_1951
summary(model_1951)
library(ggplot2)
ggplot(data = dat_1951,
aes(x = year,
y = annual_temp_c)) +
geom_point(color = "pink") +
geom_smooth(method = "lm", color = "yellow") +
xlab("Year") +
ylab("Annual Mean Air Temperature (Celcius)") +
ggtitle("Global Annual Temperature (1951–Present)") +
theme_classic()
