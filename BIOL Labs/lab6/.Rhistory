y = annual_temp_c)) + geom_smooth(method=lm)
class(dat)
class(dat$year)
class(dat$annual_temp_c)
x <- (dat$year)
y <- (dat$annual_temp_c)
summary(x)
summary(y)
model <- lm(y ~ x)
model
summary(model)
library(ggplot2)
ggplot(data = dat, aes(x = year,
y = annual_temp_c)) + geom_point(size = 2, color = "blue") +
geom_smooth(method = "lm") +
xlab("Year") +
ylab("Annual Mean Temperature (°C)") +
ggtitle("Global Annual Temperature Over Time") +
theme_classic()
library(ggplot2)
ggplot(data = dat,
