y = annual_temp_c)) +
geom_point(color = "blue", size = 2, alpha = 0.7) +
geom_smooth(method = "lm", color = "purple", linewidth = 1) +
xlab("Year") +
ylab("Annual Mean Air Temperature (°C)") +
ggtitle("Global Annual Air Temperature Over Time") +
theme_classic()
