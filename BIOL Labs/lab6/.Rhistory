library(tidyverse)
dat <- read.csv("global_temps.csv")
class(dat)
class(dat$year)
class(dat$annual_temp_c)
x <-- (dat$year)
y <--(dat$annual_temp_c)
summary(x)
summary(y)
model <- lm(y ~ x)
model
summary(model)
library(ggplot2)
ggplot(data = all_means_sd,
aes(x = drought_survival,
y = avg_depth)) + geom_smooth(method=lm)
View(dat)
library(ggplot2)
ggplot(data = y,
aes(x = year,
y = annual_temp_c)) + geom_smooth(method=lm)
geom_col(fill = "pink") +
ylab("Mean Beak Depth (mm)") +
xlab("Drought Survival") + theme_classic()
library(ggplot2)
ggplot(data = y,
aes(x = year,
y = annual_temp_c)) + geom_smooth(method=lm)
x <-- (dat$year)
y <-(dat$annual_temp_c)
class(dat$annual_temp_c)
x <-(dat$year)
