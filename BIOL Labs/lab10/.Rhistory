head(do_temp)
length(do_temp$row_id)
do_temp$date <- as.Date(do_temp$date)
str(do_temp)
lg_tempdo<-filter(do_temp, lake_id == 76)
unique(lg_tempdo$lake_id)
str(lg_tempdo)
lg_surf_tempdo <- filter(lg_tempdo, depth <= 5)
unique(lg_surf_tempdo$depth)
lg_surf_mean <- lg_surf_tempdo %>%
group_by(date)%>%
summarise(surf_temp = mean(temp), surf_do = mean(do_con))
head(lg_surf_mean)
library(lubridate)
